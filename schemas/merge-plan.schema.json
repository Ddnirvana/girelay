{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Ddnirvana/girelay/schemas/merge-plan.schema.json",
  "title": "girelay merge preview v2",
  "type": "object",
  "required": ["schema_version", "kind", "task_id", "strategy", "target_branch", "source_before", "task_before", "proposed_message", "message_source", "dirty", "final_task_commit_required", "changed_files", "commits", "checks", "divergence", "overlaps", "confirmed_conflicts", "warnings", "task_rollback_ref", "source_rollback_ref"],
  "properties": {
    "schema_version": { "const": 2 },
    "kind": { "const": "merge-plan" },
    "task_id": { "type": "string" },
    "strategy": { "enum": ["squash", "preserve"] },
    "target_branch": { "type": "string" },
    "source_before": { "type": "string" },
    "task_before": { "type": "string" },
    "proposed_message": { "type": "string" },
    "message_source": { "enum": ["argument", "intent", "task-id"] },
    "dirty": { "type": "boolean" },
    "final_task_commit_required": { "type": "boolean" },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "commits": { "type": "array" },
    "checks": { "type": "array" },
    "divergence": { "type": "object" },
    "overlaps": { "type": "array" },
    "confirmed_conflicts": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array" },
    "task_rollback_ref": { "type": "string" },
    "source_rollback_ref": { "type": "string" }
  }
}
