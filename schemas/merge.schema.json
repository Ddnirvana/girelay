{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Ddnirvana/girelay/schemas/merge.schema.json",
  "title": "girelay merge result v2",
  "type": "object",
  "required": ["schema_version", "task_id", "strategy", "target_branch", "source_before", "source_after", "task_tip", "changed_files", "checks", "task_rollback_ref", "source_rollback_ref"],
  "properties": {
    "schema_version": { "const": 2 },
    "task_id": { "type": "string" },
    "strategy": { "enum": ["squash", "preserve"] },
    "target_branch": { "type": "string" },
    "source_before": { "type": "string" },
    "source_after": { "type": "string" },
    "task_tip": { "type": "string" },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "checks": { "type": "array", "items": { "type": "string" } },
    "task_rollback_ref": { "type": "string" },
    "source_rollback_ref": { "type": "string" }
  }
}
